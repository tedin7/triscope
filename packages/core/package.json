{
  "name": "@triscope/core",
  "version": "0.0.0",
  "description": "Triscope runtime: Element contract, multi-camera lab harness, Vite telemetry plugin.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "default": "./dist/vite.js"
    },
    "./src/*": "./src/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "three": ">=0.170.0",
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jsdom": "^25.0.0",
    "three": "^0.176.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "three.js",
    "webgpu",
    "tsl",
    "ai-tools",
    "claude-code",
    "shader-tuning",
    "3d",
    "lab"
  ]
}
